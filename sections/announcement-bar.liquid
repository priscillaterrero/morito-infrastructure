<div class="marquee-bar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  <div class="marquee-bar__track">
    {%- for i in (1..3) -%}
      <div class="marquee-bar__content" {% if i > 1 %}aria-hidden="true"{% endif %}>
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <span class="marquee-bar__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="marquee-bar__link">
              {%- endif -%}
              {{ block.settings.text | escape }}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </span>
            <span class="marquee-bar__separator" aria-hidden="true">&bull;</span>
          {%- endfor -%}
        {%- else -%}
          <span class="marquee-bar__item">{{ section.settings.default_text | escape }}</span>
          <span class="marquee-bar__separator" aria-hidden="true">&bull;</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .marquee-bar {
    background-color: #332520;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
  }

  .marquee-bar__track {
    display: flex;
    width: max-content;
    animation: marqueeScroll var(--marquee-speed, 25s) linear infinite;
  }

  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  .marquee-bar__content {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .marquee-bar__item {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #F9F5F0;
    padding: 1.4rem 0;
    white-space: nowrap;
  }

  .marquee-bar__link {
    color: #F9F5F0;
    text-decoration: none;
  }

  .marquee-bar__link:hover {
    color: #D68A59;
  }

  .marquee-bar__separator {
    color: #D68A59;
    padding: 0 2rem;
    font-size: 1rem;
  }

  @media screen and (max-width: 749px) {
    .marquee-bar__item {
      font-size: 1.1rem;
      padding: 1.15rem 0;
    }

    .marquee-bar__separator {
      padding: 0 1.2rem;
    }
  }

  @media (hover: hover) {
    .marquee-bar:hover .marquee-bar__track {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-bar__track {
      animation: none;
      justify-content: center;
    }

    .marquee-bar__content:not(:first-child) {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "default_text",
      "label": "Default text (when no blocks)",
      "default": "PRE-ORDERS NOW OPEN  •  SHIPS FEB 9  •  FREE SHIPPING OVER $65  •  HANDCRAFTED IN BROOKLYN"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement",
        "settings": {
          "text": "💝 PRE-ORDERS NOW OPEN"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "SHIPS FEB 9"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "FREE SHIPPING OVER $65"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "HANDCRAFTED IN BROOKLYN"
        }
      }
    ]
  }
}
{% endschema %}
