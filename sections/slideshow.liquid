{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}


{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
  @media screen and (max-width: 749px) {
    #Slider-{{ section.id }}::before,
    #Slider-{{ section.id }} .media::before,
    #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
      padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
      content: '';
      display: block;
    }
  }

  @media screen and (min-width: 750px) {
    #Slider-{{ section.id }}::before,
    #Slider-{{ section.id }} .media::before {
      padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
      content: '';
      display: block;
    }
  }
  {%- endstyle -%}
{%- endif -%}

<slideshow-component class="slider-mobile-gutter{% if section.settings.layout == 'grid' %} page-width{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %}" role="region" aria-roledescription="{{ 'sections.slideshow.carousel' | t }}" aria-label="{{ section.settings.accessibility_info | escape }}">
  {%- if section.settings.auto_rotate and section.blocks.size > 1 -%}
    <div class="slideshow__controls slideshow__controls--top slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}" aria-controls="Slider-{{ section.id }}">{% render 'icon-caret' %}</button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        {%- else-%}
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}" aria-controls="Slider-{{ section.id }}">
                {%- if section.settings.slider_visual == 'numbers' -%}{{ forloop.index }}{% else %}<span class="dot"></span>{%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'sections.slideshow.next_slideshow' | t }}" aria-controls="Slider-{{ section.id }}">{% render 'icon-caret' %}</button>

      {%- if section.settings.auto_rotate -%}
        <button type="button" class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}" aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}">
          {%- render 'icon-pause' -%}
          {%- render 'icon-play' -%}
        </button>
      {%- endif -%}
    </div>
    <noscript>
      <div class="slider-buttons">
        <div class="slider-counter">
          {%- for block in section.blocks -%}
            <a href="#Slide-{{ section.id }}-{{ forloop.index }}" class="slider-counter__link link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}">
              {{ forloop.index }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </noscript>
  {%- endif -%}

  <div class="slideshow banner banner--{{ section.settings.slide_height }} grid grid--1-col slider slider--everywhere{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}{% if section.blocks.first.settings.image == blank %} slideshow--placeholder{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- for block in section.blocks -%}
      <style>
        #Slide-{{ section.id }}-{{ forloop.index }} .banner__media::after {
          opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
        }
      </style>
      <div class="slideshow__slide grid__item grid--1-col slider__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
        aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
        tabindex="-1"
      >
        <div class="slideshow__media banner__media media hero-kb-wrapper">
          {%- if block.settings.hero_image_file != blank -%}
            <img
              class="hero-kb-image"
              src="{{ block.settings.hero_image_file | asset_url }}"
              sizes="100vw"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              alt="{{ block.settings.heading | escape }} — Morito Chocolates"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          {%- elsif block.settings.image -%}
            <img
              class="hero-kb-image"
              src="{{ block.settings.image | image_url: width: 1920 }}"
              srcset="{{ block.settings.image | image_url: width: 750 }} 750w,
                      {{ block.settings.image | image_url: width: 1100 }} 1100w,
                      {{ block.settings.image | image_url: width: 1500 }} 1500w,
                      {{ block.settings.image | image_url: width: 1920 }} 1920w"
              sizes="100vw"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
              {% if forloop.first %}fetchpriority="high"{% endif %}
            >
          {%- else -%}
            <img
              class="hero-kb-image"
              src="{{ 'Heroimage.jpg' | asset_url }}"
              sizes="100vw"
              loading="eager"
              alt="Morito Chocolates"
              fetchpriority="high"
            >
          {%- endif -%}
          <div class="hero-overlay" aria-hidden="true"></div>
        </div>
        <div class="slideshow__text-wrapper banner__content banner__content--{{ block.settings.box_align }}{% if block.settings.show_text_box == false %} banner--desktop-transparent{% endif %}">
          <div class="slideshow__text banner__box content-container content-container--full-width-mobile color-{{ block.settings.color_scheme }} gradient slideshow__text--{{ block.settings.text_alignment }} slideshow__text-mobile--{{ block.settings.text_alignment_mobile }}{% if block.settings.glass_effect %} glass-effect{% endif %}">
            {%- if block.settings.heading != blank -%}
              <h2 class="banner__heading first {{ block.settings.heading_size }}">{{ block.settings.heading | escape }}</h2>
             <h2 class="banner__heading second {{ block.settings.heading_size }}">{{ block.settings.heading2 | escape }}</h2>
            <h2 class="banner__heading third {{ block.settings.heading_size }}">{{ block.settings.heading3 | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="banner__text" {{ block.shopify_attributes }}>
                <span>{{ block.settings.subheading | escape }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
        {%- if block.settings.button_label != blank -%}
          <div class="banner__buttons">
            <a{% if block.settings.link %} href="{{ block.settings.link }}"{% else %} role="link" aria-disabled="true"{% endif %} class="button-banner">{{ block.settings.button_label | escape }}</a>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 and section.settings.auto_rotate == false -%}
    <div class="slideshow__controls slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}" aria-controls="Slider-{{ section.id }}">{% render 'icon-caret' %}</button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        {%- else-%}
          <div class="slideshow__control-wrapper">
            {%- for block in section.blocks -%}
              <button class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}" aria-controls="Slider-{{ section.id }}">
                {%- if section.settings.slider_visual == 'numbers' -%}{{ forloop.index }}{% else %}<span class="dot"></span>{%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'sections.slideshow.next_slideshow' | t }}" aria-controls="Slider-{{ section.id }}">{% render 'icon-caret' %}</button>

      {%- if section.settings.auto_rotate -%}
        <button type="button" class="slideshow__autoplay slider-button no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}" aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}">
          {%- render 'icon-pause' -%}
          {%- render 'icon-play' -%}
        </button>
      {%- endif -%}
    </div>
    <noscript>
      <div class="slider-buttons">
        <div class="slider-counter">
          {%- for block in section.blocks -%}
            <a href="#Slide-{{ section.id }}-{{ forloop.index }}" class="slider-counter__link link" aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}">
              {{ forloop.index }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </noscript>
  {%- endif -%}
</slideshow-component>

<style>
  /* ── Ken Burns animation on hero image ── */
  .hero-kb-wrapper {
    position: relative;
    overflow: hidden;
  }

  .hero-kb-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: kenBurns 22s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes kenBurns {
    0%   { transform: scale(1)    translate(0, 0); }
    40%  { transform: scale(1.08) translate(-0.5%, -0.8%); }
    70%  { transform: scale(1.05) translate(0.5%, 0.3%); }
    100% { transform: scale(1)    translate(0, 0); }
  }

  /* Reduced zoom for slides with glass effect (corporate/gifting) */
  @keyframes kenBurnsSubtle {
    0%   { transform: scale(1)    translate(0, 0); }
    50%  { transform: scale(1.03) translate(-0.2%, -0.3%); }
    100% { transform: scale(1)    translate(0, 0); }
  }

  .slideshow__slide:has(.glass-effect) .hero-kb-image {
    animation: kenBurnsSubtle 18s ease-in-out infinite;
    object-position: center center;
  }

  /* ── Dark gradient overlay for text contrast ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(51, 37, 32, 0.15) 0%,
      rgba(51, 37, 32, 0.30) 40%,
      rgba(51, 37, 32, 0.60) 75%,
      rgba(51, 37, 32, 0.75) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Ensure text sits above overlay ── */
  .slideshow__text-wrapper.banner__content {
    z-index: 2;
    position: relative;
  }

  .banner__buttons {
    z-index: 3;
  }

  /* ── Hero fadeInUp animation ── */
  .slideshow__text .banner__heading,
  .slideshow__text .banner__text,
  .banner__buttons {
    opacity: 0;
    transform: translateY(30px);
    animation: heroFadeInUp 1.2s ease-out forwards;
  }

  .slideshow__text .banner__heading.first  { animation-delay: 0.2s; }
  .slideshow__text .banner__heading.second { animation-delay: 0.5s; }
  .slideshow__text .banner__heading.third  { animation-delay: 0.8s; }
  .slideshow__text .banner__text           { animation-delay: 1.1s; }
  .banner__buttons                         { animation-delay: 1.4s; }

  @keyframes heroFadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Hero heading — Organic Luxury palette ── */
  h2.banner__heading {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  h2.banner__heading.first {
    background-color: #332520;
    color: #F9F5F0;
  }

  h2.banner__heading.second,
  h2.banner__heading.third {
    background-color: #F9F5F0;
    color: #332520;
  }

  /* ── Hero subtitle — improved contrast ── */
  .slideshow__text .banner__text {
    margin-top: 16px;
  }

  .slideshow__text .banner__text span {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: #F9F5F0;
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.6),
      0 2px 12px rgba(0, 0, 0, 0.35);
    letter-spacing: 0.04em;
    background-color: rgba(51, 37, 32, 0.40);
    padding: 8px 20px;
    border-radius: 4px;
    display: inline-block;
  }

  /* ── "Shop Now" button — improved contrast ── */
  .banner__buttons a.button-banner {
    color: #F9F5F0;
    background-color: rgba(51, 37, 32, 0.45);
    border: 2px solid #F9F5F0;
    text-decoration: none;
    padding: 15px 35px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.95rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
    transition: background-color 0.3s ease, transform 0.3s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  @media (hover: hover) {
    .banner__buttons a.button-banner:hover {
      background-color: #D68A59;
      border-color: #D68A59;
      color: #fff;
      transform: translateY(-2px);
    }
  }

  /* ═══════════════════════════════════════════════════
     MOBILE — Slide fits viewport WITH header visible
     Header (~60px) + Announcement bar (~40px) = ~100px
     Slide = 100dvh - 100px = remaining viewport
     ═══════════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {

    /* ── Slide: fit remaining viewport after header ── */
    .slideshow__slide.grid__item {
      position: relative !important;
      width: 100vw;
      height: calc(100dvh - 100px); /* viewport minus header + announcement bar */
      max-height: calc(100dvh - 100px);
      overflow: hidden;
    }

    /* ── Image: cover the slide area perfectly ── */
    .slideshow__slide .slideshow__media.banner__media {
      position: absolute !important;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .slideshow__slide .hero-kb-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 35%;
      animation-duration: 18s;
      animation-name: kenBurnsMobile;
    }

    /* Mobile Ken Burns: reduced zoom so product feels complete with breathing room */
    @keyframes kenBurnsMobile {
      0%   { transform: scale(1)    translate(0, 0); }
      40%  { transform: scale(1.04) translate(-0.3%, -0.4%); }
      70%  { transform: scale(1.02) translate(0.2%, 0.2%); }
      100% { transform: scale(1)    translate(0, 0); }
    }

    /* ── Optimized overlay: clear center, dark bottom for text ── */
    .slideshow__slide .hero-overlay {
      background: linear-gradient(
        180deg,
        rgba(51, 37, 32, 0.30) 0%,
        rgba(51, 37, 32, 0.05) 25%,
        rgba(51, 37, 32, 0.05) 50%,
        rgba(51, 37, 32, 0.50) 75%,
        rgba(51, 37, 32, 0.72) 100%
      );
    }

    /* ── Text wrapper: anchored to bottom, over image ── */
    .slideshow__slide .slideshow__text-wrapper.banner__content {
      position: absolute !important;
      bottom: 50px; /* space for button below */
      left: 0;
      right: 0;
      top: auto !important;
      padding: 0 16px;
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      pointer-events: none;
    }

    .slideshow__slide .slideshow__text.banner__box {
      background: transparent !important;
      padding: 0;
      margin: 0;
      pointer-events: auto;
    }

    /* ── Headings: no bg, text-shadow for contrast, +2pt vs before ── */
    .slideshow__slide h2.banner__heading {
      font-size: 26px; /* was 24px → +2pt */
      line-height: 32px;
      margin-bottom: 1px;
      background: none !important;
      padding: 0;
      text-shadow:
        0 1px 3px rgba(0, 0, 0, 0.8),
        0 2px 10px rgba(0, 0, 0, 0.5),
        0 0 20px rgba(0, 0, 0, 0.3);
    }

    .slideshow__slide h2.banner__heading.first {
      color: #F9F5F0;
    }

    .slideshow__slide h2.banner__heading.second {
      color: #D68A59;
    }

    .slideshow__slide h2.banner__heading.third {
      color: #F9F5F0;
    }

    /* ── Subtitle: clean, with spacing to avoid button overlap ── */
    .slideshow__slide .slideshow__text .banner__text {
      margin-top: 6px;
      margin-bottom: 0;
    }

    .slideshow__slide .slideshow__text .banner__text span {
      font-size: 0.82rem;
      padding: 0;
      background: none;
      color: #F9F5F0;
      text-shadow:
        0 1px 3px rgba(0, 0, 0, 0.8),
        0 2px 8px rgba(0, 0, 0, 0.4);
      opacity: 0.9;
      letter-spacing: 0.05em;
    }

    /* ── Button: absolute bottom-right, BELOW text to prevent overlap ── */
    .slideshow__slide .banner__buttons {
      position: absolute;
      bottom: 14px;
      right: 16px;
      left: auto;
      padding: 0;
    }

    .slideshow__slide .banner__buttons a.button-banner {
      padding: 9px 18px;
      font-size: 0.72rem;
      background-color: rgba(214, 138, 89, 0.85);
      border: 1.5px solid #D68A59;
      color: #fff;
      text-shadow: none;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border-radius: 3px;
      letter-spacing: 0.1em;
    }

    .slideshow__slide .banner__buttons a.button-banner:active {
      background-color: #c07a4e;
      transform: scale(0.97);
    }
  }

  /* ── Small phones (iPhone SE, Galaxy A series) ── */
  @media screen and (max-width: 374px) {
    .slideshow__slide.grid__item {
      height: calc(100dvh - 90px);
      max-height: calc(100dvh - 90px);
    }

    .slideshow__slide h2.banner__heading {
      font-size: 22px;
      line-height: 28px;
    }

    .slideshow__slide .slideshow__text .banner__text span {
      font-size: 0.75rem;
    }

    .slideshow__slide .banner__buttons a.button-banner {
      padding: 8px 14px;
      font-size: 0.68rem;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .slideshow__text .banner__heading,
    .slideshow__text .banner__text,
    .banner__buttons {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .hero-kb-image {
      animation: none;
    }
  }

  /* ═══════════════════════════════════════════════════
     GLASS EFFECT - Elegant translucent text box
     For Corporate Gifting and special slides
     ═══════════════════════════════════════════════════ */
  .slideshow__text.glass-effect {
    background: rgba(249, 245, 240, 0.45) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    padding: 40px 55px !important;
    box-shadow:
      0 8px 32px rgba(51, 37, 32, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.4);
    max-width: 650px;
    width: fit-content;
  }

  .slideshow__text.glass-effect h2.banner__heading {
    background: none !important;
    color: #332520 !important;
    text-shadow: none;
    padding: 0;
    margin-bottom: 4px;
    white-space: normal;
  }

  .slideshow__text.glass-effect h2.banner__heading.first {
    color: #D68A59 !important;
  }

  .slideshow__text.glass-effect .banner__text span {
    background: none;
    color: #332520;
    text-shadow: none;
    padding: 0;
    font-size: 1.1rem;
    opacity: 0.85;
  }

  /* Glass effect text alignment variants */
  .slideshow__text.glass-effect.slideshow__text--left {
    text-align: left;
  }

  .slideshow__text.glass-effect.slideshow__text--right {
    text-align: right;
  }

  /* Glass effect button inside the box */
  .glass-effect + .banner__buttons,
  .slideshow__slide:has(.glass-effect) .banner__buttons {
    margin-top: 20px;
  }

  .slideshow__slide:has(.glass-effect) .banner__buttons a.button-banner {
    background-color: #332520;
    border-color: #332520;
    color: #F9F5F0;
    text-shadow: none;
  }

  .slideshow__slide:has(.glass-effect) .banner__buttons a.button-banner:hover {
    background-color: #D68A59;
    border-color: #D68A59;
  }

  /* ═══════════════════════════════════════════════════
     MOBILE GLASS EFFECT - Matches slides 1 & 2 style
     Clean text overlay without opaque box
     ═══════════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    /* Override glass effect on mobile to match clean text style */
    .slideshow__text.glass-effect {
      background: none !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      max-width: 100%;
      margin: 0;
      border-radius: 0;
    }

    .slideshow__text.glass-effect h2.banner__heading {
      font-size: 24px !important;
      line-height: 30px !important;
      white-space: normal;
      color: #F9F5F0 !important;
      text-shadow:
        0 1px 3px rgba(0, 0, 0, 0.8),
        0 2px 10px rgba(0, 0, 0, 0.5),
        0 0 20px rgba(0, 0, 0, 0.3) !important;
    }

    .slideshow__text.glass-effect h2.banner__heading.first {
      color: #F9F5F0 !important;
    }

    .slideshow__text.glass-effect h2.banner__heading.second {
      color: #D68A59 !important;
    }

    .slideshow__text.glass-effect h2.banner__heading.third {
      color: #F9F5F0 !important;
    }

    .slideshow__text.glass-effect .banner__text span {
      background: none;
      color: #F9F5F0;
      font-size: 0.82rem;
      text-shadow:
        0 1px 3px rgba(0, 0, 0, 0.8),
        0 2px 8px rgba(0, 0, 0, 0.4);
      opacity: 0.9;
    }

    /* Position text at bottom left like slides 1 & 2 */
    .slideshow__slide:has(.glass-effect) .slideshow__text-wrapper.banner__content {
      bottom: 50px;
      left: 0;
      right: 0;
      display: flex;
      justify-content: flex-start;
      padding: 0 16px;
    }

    .slideshow__slide:has(.glass-effect) .slideshow__text.glass-effect {
      text-align: left !important;
    }

    .slideshow__slide:has(.glass-effect) .banner__buttons {
      bottom: 14px;
      right: 16px;
      left: auto;
      transform: none;
    }

    .slideshow__slide:has(.glass-effect) .banner__buttons a.button-banner {
      background-color: rgba(214, 138, 89, 0.85);
      border: 1.5px solid #D68A59;
      color: #fff;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
  }
</style>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

