<style>
  .positioning-statement {
    background: #F5EFEA;
    border-top: 1px solid rgba(193, 119, 82, 0.12);
    border-bottom: 1px solid rgba(193, 119, 82, 0.12);
    text-align: center;
    padding: 100px 20px 90px;
  }

  .positioning-statement__ornament {
    display: block;
    width: 36px;
    height: 1px;
    background-color: #C8A68E;
    border: none;
    margin: 0 auto 32px;
    opacity: 0.5;
  }

  .positioning-statement__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.1rem, 4.2vw, 3.4rem);
    font-weight: 600;
    font-style: italic;
    color: #3B2820;
    margin: 0 auto;
    max-width: 820px;
    letter-spacing: 0.015em;
    line-height: 1.4;
  }

  .positioning-statement__subline-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 300;
    font-style: italic;
    color: #6B5349;
    margin: 12px auto 0;
    max-width: 820px;
    letter-spacing: 0.015em;
    line-height: 1.45;
  }

  .positioning-statement__divider {
    width: 36px;
    height: 1px;
    background-color: #C8A68E;
    border: none;
    margin: 32px auto 0;
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .positioning-statement {
      padding: 70px 28px 60px;
    }

    .positioning-statement__headline {
      font-size: 1.65rem;
      line-height: 1.45;
    }

    .positioning-statement__subline-text {
      font-size: 1.25rem;
      margin-top: 8px;
    }
  }
</style>

<section class="positioning-statement">
  <span class="positioning-statement__ornament" aria-hidden="true"></span>
  <h2 class="positioning-statement__headline">{{ section.settings.headline | escape }}</h2>
  {%- if section.settings.subline != blank -%}
    <p class="positioning-statement__subline-text">{{ section.settings.subline | escape }}</p>
  {%- endif -%}
  <hr class="positioning-statement__divider">
</section>

{% schema %}
{
  "name": "Positioning Statement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Cacao-Driven Confections"
    },
    {
      "type": "text",
      "id": "subline",
      "label": "Subline",
      "default": "Handcrafted in Brooklyn"
    }
  ],
  "presets": [
    {
      "name": "Positioning Statement"
    }
  ]
}
{% endschema %}
