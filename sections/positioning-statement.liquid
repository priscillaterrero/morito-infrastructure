<style>
  .positioning-statement {
    background: #F5EFEA;
    text-align: center;
    padding: 36px 20px 42px;
  }

  .positioning-statement__ornament {
    display: block;
    width: 80px;
    height: 3px;
    background-color: #C8652A;
    border: none;
    margin: 0 auto 28px;
  }

  .positioning-statement__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 4.8vw, 3.8rem);
    font-weight: 700;
    font-style: italic;
    color: #2E221C;
    margin: 0 auto;
    max-width: 840px;
    letter-spacing: 0.01em;
    line-height: 1.35;
  }

  .positioning-statement__subline-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    font-weight: 300;
    font-style: italic;
    color: #6B5349;
    margin: 14px auto 0;
    max-width: 840px;
    letter-spacing: 0.015em;
    line-height: 1.45;
  }

  .positioning-statement__diamond {
    display: block;
    width: 10px;
    height: 10px;
    background-color: #C8652A;
    border: none;
    margin: 28px auto 0;
    transform: rotate(45deg);
  }

  @media screen and (max-width: 989px) {
    .positioning-statement {
      padding: 32px 24px 38px;
    }

    .positioning-statement__ornament {
      width: 60px;
      margin-bottom: 22px;
    }

    .positioning-statement__diamond {
      width: 8px;
      height: 8px;
      margin-top: 22px;
    }
  }

  @media screen and (max-width: 749px) {
    .positioning-statement {
      padding: 28px 20px 34px;
    }

    .positioning-statement__ornament {
      width: 50px;
      height: 2px;
      margin-bottom: 18px;
    }

    .positioning-statement__headline {
      font-size: clamp(1.5rem, 5vw, 1.85rem);
      line-height: 1.4;
      max-width: 90%;
    }

    .positioning-statement__subline-text {
      font-size: 1.35rem;
      margin-top: 10px;
    }

    .positioning-statement__diamond {
      width: 7px;
      height: 7px;
      margin-top: 18px;
    }
  }
</style>

<section class="positioning-statement">
  <span class="positioning-statement__ornament" aria-hidden="true"></span>
  <h2 class="positioning-statement__headline">{{ section.settings.headline | escape }}</h2>
  {%- if section.settings.subline != blank -%}
    <p class="positioning-statement__subline-text">{{ section.settings.subline | escape }}</p>
  {%- endif -%}
  <span class="positioning-statement__diamond" aria-hidden="true"></span>
</section>

{% schema %}
{
  "name": "Positioning Statement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Cacao-Driven Confections"
    },
    {
      "type": "text",
      "id": "subline",
      "label": "Subline",
      "default": "Handcrafted in Brooklyn"
    }
  ],
  "presets": [
    {
      "name": "Positioning Statement"
    }
  ]
}
{% endschema %}
