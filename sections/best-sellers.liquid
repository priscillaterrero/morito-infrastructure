{%- comment -%}
  Best Sellers — Subtle hover zoom with HD images & viewport-triggered entrance
{%- endcomment -%}

<style>
  /* ── Best Sellers Section ── */
  .best-sellers {
    background-color: #F9F5F0;
    padding: 60px 0 80px;
  }

  .best-sellers__header {
    text-align: center;
    margin-bottom: 50px;
  }

  .best-sellers__title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 2.8rem;
    color: #332520;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .best-sellers__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: #332520;
    opacity: 0.65;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── 3-Column Grid ── */
  .best-sellers__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Product Card ── */
  .best-sellers__card {
    background: transparent;
    border: none;
    border-radius: 8px;
    overflow: visible;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: none;
    transition:
      transform 0.4s ease,
      box-shadow 0.4s ease;
    will-change: transform;
  }

  /* ── Scroll-triggered highlight glow ── */
  .best-sellers__card {
    opacity: 0;
    transform: translateY(30px);
  }

  .best-sellers__card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered entrance per card */
  .best-sellers__card:nth-child(1) { transition-delay: 0s; }
  .best-sellers__card:nth-child(2) { transition-delay: 0.15s; }
  .best-sellers__card:nth-child(3) { transition-delay: 0.3s; }

  /* ── Subtle Zoom + Shadow Hover (Desktop) ── */
  @media (hover: hover) {
    .best-sellers__card:hover {
      transform: scale(1.05);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .best-sellers__card:hover .best-sellers__image-wrapper img {
      transform: scale(1.08);
    }

    .best-sellers__card:hover .best-sellers__product-title {
      color: #D68A59;
    }
  }

  .best-sellers__product-title {
    transition: color 0.35s ease;
  }

  /* ── Image Wrapper — seamless background fusion ── */
  .best-sellers__image-wrapper {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .best-sellers__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border: none;
    outline: none;
    image-rendering: -webkit-optimize-contrast;
    filter: drop-shadow(0 18px 25px rgba(51, 37, 32, 0.18));
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .best-sellers__image-link {
    display: block;
    text-decoration: none;
    border: none;
    outline: none;
  }

  /* ── Product Info ── */
  .best-sellers__info {
    text-align: center;
    padding: 20px 10px 15px;
    background: transparent;
    position: relative;
  }

  .best-sellers__product-title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.35rem;
    color: #332520;
    margin: 0 0 8px;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .best-sellers__product-title a {
    color: inherit;
    text-decoration: none;
  }

  .best-sellers__price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #3E2117;
    margin: 0 0 18px;
  }

  /* ── Add to Cart Button — Always visible, high-contrast CTA ── */
  .best-sellers__add-btn {
    display: inline-block;
    background-color: #D68A59;
    color: #FFFFFF;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    padding: 15px 30px;
    cursor: pointer;
    border-radius: 4px;
    transition:
      background-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .best-sellers__add-btn:hover {
    background-color: #BF7A4E;
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(214, 138, 89, 0.35);
  }

  .best-sellers__add-btn--visible {
    text-decoration: none;
    display: inline-block;
  }

  .best-sellers__add-form {
    margin: 0;
    padding: 0;
  }

  /* ── "View All" link ── */
  .best-sellers__view-all {
    text-align: center;
    margin-top: 50px;
  }

  .best-sellers__view-all a {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #332520;
    text-decoration: none;
    border-bottom: 2px solid #D68A59;
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  @media (hover: hover) {
    .best-sellers__view-all a:hover {
      color: #D68A59;
    }
  }

  /* ═══════════════════════════════════════════════════
     DESKTOP ≥990px — Luxury Scale & 3D depth
     ═══════════════════════════════════════════════════ */
  @media screen and (min-width: 990px) {
    .best-sellers__product-title {
      font-size: 2.2rem;
      line-height: 1.15;
      margin-bottom: 12px;
    }

    .best-sellers__price {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 22px;
    }

    .best-sellers__add-btn {
      font-size: 1.1rem;
      padding: 15px 40px;
    }

    .best-sellers__info {
      padding: 30px 18px 24px;
    }
  }

  /* ═══════════════════════════════════════════════════
     MOBILE — Viewport-triggered levitation
     ═══════════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    .best-sellers {
      padding: 40px 0 60px;
    }

    .best-sellers__grid {
      grid-template-columns: 1fr;
      gap: 45px;
      padding: 0 28px;
      max-width: 480px;
    }

    .best-sellers__title {
      font-size: 2rem;
    }

    .best-sellers__info {
      padding: 22px 16px 18px;
    }

    .best-sellers__product-title {
      font-size: 1.35rem;
      margin-bottom: 8px;
    }

    .best-sellers__price {
      font-size: 1.15rem;
      margin-bottom: 20px;
    }

    .best-sellers__add-btn {
      font-size: 0.95rem;
      padding: 14px 28px;
      width: 100%;
    }

    /* ── Mobile scroll highlight — active card gets zoom + shadow ── */
    .best-sellers__card.is-active {
      transform: scale(1.05);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .best-sellers__card.is-active .best-sellers__image-wrapper img {
      transform: scale(1.08);
    }
  }

  /* ── Tablet: 2 Columns ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .best-sellers__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .best-sellers__product-title {
      font-size: 1.5rem;
    }

    .best-sellers__price {
      font-size: 1.2rem;
    }
  }

  /* ── Reduced Motion ── */
  @media (prefers-reduced-motion: reduce) {
    .best-sellers__card,
    .best-sellers__image-wrapper img,
    .best-sellers__info,
    .best-sellers__add-btn {
      transition: none !important;
    }

    .best-sellers__card:hover {
      transform: none !important;
    }

    .best-sellers__card {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<section class="best-sellers" id="BestSellers-{{ section.id }}">
  <div class="best-sellers__header page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="best-sellers__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="best-sellers__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>

  <div class="best-sellers__grid">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <div class="best-sellers__card" {{ block.shopify_attributes }}>
        <a href="{{ product.url | default: '#' }}" class="best-sellers__image-link" aria-label="{{ product.title | escape | default: block.settings.image_file }}">
          <div class="best-sellers__image-wrapper">
            {%- if block.settings.image_url != blank -%}
              <img
                src="{{ block.settings.image_url }}"
                alt="{{ product.title | escape | default: 'Product image' }}"
                loading="lazy"
                width="1200"
                height="1200"
              >
            {%- elsif block.settings.image_file != blank -%}
              <img
                src="{{ block.settings.image_file | asset_url }}"
                alt="{{ product.title | escape | default: block.settings.image_file }}"
                loading="lazy"
                width="1200"
                height="1200"
              >
            {%- elsif product.featured_media -%}
              <img
                src="{{ product.featured_media | image_url: width: 1200 }}"
                alt="{{ product.featured_media.alt | escape }}"
                loading="lazy"
                width="1200"
                height="1200"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </a>

        <div class="best-sellers__info">
          {%- if product != blank -%}
            <h3 class="best-sellers__product-title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <p class="best-sellers__price">{{ product.price | money }}</p>
            <form method="post" action="/cart/add" class="best-sellers__add-form">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="best-sellers__add-btn">Add to Cart</button>
            </form>
          {%- else -%}
            <h3 class="best-sellers__product-title">{{ block.settings.image_file | remove: '.jpeg' | remove: '.jpg' | remove: '.png' }}</h3>
            <a href="/collections/all-products" class="best-sellers__add-btn best-sellers__add-btn--visible">Shop Now</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.show_view_all and section.settings.collection != blank -%}
    <div class="best-sellers__view-all">
      <a href="{{ section.settings.collection.url }}">View All</a>
    </div>
  {%- endif -%}
</section>

<script>
  (function() {
    'use strict';

    var isMobile = window.matchMedia('(max-width: 749px)');

    /* ═══════════════════════════════════════════════════
       INTERSECTION OBSERVER — Viewport entrance (all devices)
       Cards fade-in + slide-up with stagger when scrolled into view.
       On mobile, the most-centered card also gets .is-active highlight.
       ═══════════════════════════════════════════════════ */
    function initViewportEntrance() {
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.best-sellers__card').forEach(function(c) {
          c.classList.add('is-visible');
        });
        return;
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.12,
        rootMargin: '0px 0px -60px 0px'
      });

      document.querySelectorAll('.best-sellers__card').forEach(function(card) {
        if (!card.classList.contains('is-visible')) {
          observer.observe(card);
        }
      });
    }

    /* ═══════════════════════════════════════════════════
       MOBILE SCROLL HIGHLIGHT — Center-most card gets
       .is-active for zoom + shadow effect
       ═══════════════════════════════════════════════════ */
    function initMobileScrollHighlight() {
      if (!isMobile.matches) return;
      if (!('IntersectionObserver' in window)) return;

      var cards = document.querySelectorAll('.best-sellers__card');
      var activeObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-active');
          } else {
            entry.target.classList.remove('is-active');
          }
        });
      }, {
        threshold: 0.6,
        rootMargin: '-10% 0px -10% 0px'
      });

      cards.forEach(function(card) {
        activeObserver.observe(card);
      });
    }

    /* Init on DOM ready */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        initViewportEntrance();
        initMobileScrollHighlight();
      });
    } else {
      initViewportEntrance();
      initMobileScrollHighlight();
    }

    /* Re-init on media query change (resize/orientation) */
    isMobile.addEventListener('change', function() {
      initMobileScrollHighlight();
    });
  })();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Best Sellers / Perfect Gifting",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our most-loved chocolate sticks — handcrafted in Brooklyn."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": false,
      "label": "Show 'View All' link"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "image_file",
          "label": "HD Image filename (from assets/)",
          "info": "Exact filename including extension, e.g. Coconut Vegan White Chocolate.jpeg"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Direct CDN Image URL",
          "info": "Full Shopify CDN URL. Overrides HD Image filename if provided."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "image_file": "Coconut Vegan White Chocolate.jpeg"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_file": "Hazelnu Dark Chocolate.jpeg"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "image_file": "Salted Peanut Dark chocolate.jpeg"
          }
        }
      ]
    }
  ]
}
{% endschema %}
