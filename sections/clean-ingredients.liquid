<style>
  .clean-ingredients {
    background-color: #FAF8F5;
    padding: 90px 20px;
  }

  .clean-ingredients__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .clean-ingredients__columns {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  /* ── Left text column ── */
  .clean-ingredients__text {
    flex: 1;
    max-width: 560px;
  }

  .clean-ingredients__headline {
    font-family: 'Playfair Display', serif;
    color: #332520;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .clean-ingredients__headline-top {
    display: block;
    font-style: italic;
    font-weight: 500;
    font-size: 3.2rem;
  }

  .clean-ingredients__headline-bottom {
    display: block;
    font-weight: 900;
    font-size: 5.2rem;
    margin-top: 6px;
  }

  /* ── Right image column ── */
  .clean-ingredients__image {
    flex: 1;
    max-width: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .clean-ingredients__image img {
    width: 60%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* ── Bottom attributes row ── */
  .clean-ingredients__attributes {
    max-width: 1040px;
    margin: 70px auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .clean-ingredients__attribute {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: #332520;
    padding: 0 32px;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .clean-ingredients__attribute--upper {
    text-transform: uppercase;
    font-weight: 800;
    font-size: 1.7rem;
    letter-spacing: 0.12em;
  }

  .clean-ingredients__divider {
    flex: 0 0 60px;
    border: none;
    border-top: 2px dotted #D68A59;
    margin: 0;
    height: 0;
  }

  /* ═══════ Tablet ═══════ */
  @media screen and (max-width: 989px) {
    .clean-ingredients__headline-top { font-size: 2.6rem; }
    .clean-ingredients__headline-bottom { font-size: 4rem; }
    .clean-ingredients__columns { gap: 16px; }
  }

  /* ═══════ Mobile ═══════ */
  @media screen and (max-width: 749px) {
    .clean-ingredients { padding: 56px 18px; }

    .clean-ingredients__columns {
      flex-direction: column;
      gap: 12px;
    }

    .clean-ingredients__text { text-align: center; }

    .clean-ingredients__headline-top { font-size: 2.2rem; }
    .clean-ingredients__headline-bottom { font-size: 3.2rem; }

    .clean-ingredients__attributes {
      margin-top: 44px;
      gap: 10px 0;
    }

    .clean-ingredients__attribute {
      font-size: 1.3rem;
      padding: 0 18px;
    }

    .clean-ingredients__divider { flex-basis: 28px; }
  }
</style>

<div class="clean-ingredients">
  <div class="clean-ingredients__container">
    <div class="clean-ingredients__columns">
      <div class="clean-ingredients__text">
        <h2 class="clean-ingredients__headline">
          <span class="clean-ingredients__headline-top">{{ section.settings.headline_top | escape }}</span>
          <span class="clean-ingredients__headline-bottom">{{ section.settings.headline_bottom | escape }}</span>
        </h2>
      </div>

      <div class="clean-ingredients__image">
        {%- if section.settings.image_url != blank -%}
          <img src="{{ section.settings.image_url }}" alt="{{ section.settings.image_alt | escape }}" loading="lazy">
        {%- elsif section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | default: section.settings.image_alt | escape }}" loading="lazy" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="clean-ingredients__attributes">
      <span class="clean-ingredients__attribute">{{ section.settings.attr_1 | escape }}</span>
      <hr class="clean-ingredients__divider">
      <span class="clean-ingredients__attribute clean-ingredients__attribute--upper">{{ section.settings.attr_2 | escape }}</span>
      <hr class="clean-ingredients__divider">
      <span class="clean-ingredients__attribute">{{ section.settings.attr_3 | escape }}</span>
      <hr class="clean-ingredients__divider">
      <span class="clean-ingredients__attribute">{{ section.settings.attr_4 | escape }}</span>
      <hr class="clean-ingredients__divider">
      <span class="clean-ingredients__attribute clean-ingredients__attribute--upper">{{ section.settings.attr_5 | escape }}</span>
      <hr class="clean-ingredients__divider">
      <span class="clean-ingredients__attribute">{{ section.settings.attr_6 | escape }}</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Clean Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline_top",
      "label": "Headline (italic line)",
      "default": "Decadent flavors;"
    },
    {
      "type": "text",
      "id": "headline_bottom",
      "label": "Headline (bold line)",
      "default": "Simple ingredients"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "image_url",
      "label": "Direct CDN image URL (overrides picker)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Morito chocolate"
    },
    { "type": "header", "content": "Attributes row" },
    { "type": "text", "id": "attr_1", "label": "Attribute 1", "default": "vegan" },
    { "type": "text", "id": "attr_2", "label": "Attribute 2", "default": "ZERO PRESERVATIVES" },
    { "type": "text", "id": "attr_3", "label": "Attribute 3", "default": "gluten free" },
    { "type": "text", "id": "attr_4", "label": "Attribute 4", "default": "soy free" },
    { "type": "text", "id": "attr_5", "label": "Attribute 5", "default": "NON GMO" },
    { "type": "text", "id": "attr_6", "label": "Attribute 6", "default": "palm oil free" }
  ],
  "presets": [
    {
      "name": "Clean Ingredients"
    }
  ]
}
{% endschema %}
