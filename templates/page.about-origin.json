        "image_text_3fNeJY": {
          "type": "image-text",
          "settings": {
            "image": "shopify://shop_images/Screenshot_2026-02-07_at_8.19.08_AM.png",
            "content": "<p>Cacao defines the structure, texture, and depth of everything we create. From there, we layer complementary ingredients — selected to highlight, never to overpower.</p><p>By working with a minimal number of ingredients, we allow cacao to come through with clarity, creating a balanced and intentional expression in every piece.</p><p>In a category often driven by sweetness and excess, we choose restraint — allowing each component to serve a purpose.</p>"
          }
        },
        "c5a6c078-3a6b-4137-92fb-a49f71c5bf0a": {
